-- ----------------------------
-- 4. 评论表
-- ----------------------------
DROP TABLE IF EXISTS `comments`;
CREATE TABLE `comments` (
  `comment_id` INT PRIMARY KEY AUTO_INCREMENT NOT NULL COMMENT '评论ID',
  `weibo_id` INT NOT NULL COMMENT '微博ID',
  `user_id` INT NOT NULL COMMENT '评论人',
  `content` TEXT NOT NULL COMMENT '内容',
  `parent_id` INT DEFAULT NULL COMMENT '父评论',
  `create_time` DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '时间',
  FOREIGN KEY (`weibo_id`) REFERENCES `weibo_posts`(`weibo_id`),
  FOREIGN KEY (`user_id`) REFERENCES `users`(`user_id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='评论表';

