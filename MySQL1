-- 5. 点赞表
-- ----------------------------
DROP TABLE IF EXISTS `likes`;
CREATE TABLE `likes` (
  `like_id` INT PRIMARY KEY AUTO_INCREMENT NOT NULL COMMENT '点赞ID',
  `user_id` INT NOT NULL COMMENT '用户ID',
