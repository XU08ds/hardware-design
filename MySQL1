-- ----------------------------
-- 7. 私信表
-- ----------------------------
DROP TABLE IF EXISTS `messages`;
CREATE TABLE `messages` (
  `message_id` INT PRIMARY KEY AUTO_INCREMENT NOT NULL COMMENT '私信ID',
  `sender_id` INT NOT NULL COMMENT '发送者',
  `receiver_id` INT NOT NULL COMMENT '接收者',
  `content` TEXT NOT NULL COMMENT '内容',
  `create_time` DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '时间',
  `is_read` ENUM('是','否') DEFAULT '否' COMMENT '已读',
  FOREIGN KEY (`sender_id`) REFERENCES `users`(`user_id`),
  FOREIGN KEY (`receiver_id`) REFERENCES `users`(`user_id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='私信表';

