-- 8. 通知表
-- ----------------------------
DROP TABLE IF EXISTS `notifications`;
CREATE TABLE `notifications` (
  `notice_id` INT PRIMARY KEY AUTO_INCREMENT NOT NULL COMMENT '通知ID',
