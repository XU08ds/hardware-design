-- ----------------------------
-- 6. 关注表
-- ----------------------------
DROP TABLE IF EXISTS `follows`;
CREATE TABLE `follows` (
  `follow_id` INT PRIMARY KEY AUTO_INCREMENT NOT NULL COMMENT '关注ID',
  `follower_id` INT NOT NULL COMMENT '关注者',
  `followed_id` INT NOT NULL COMMENT '被关注者',
  `create_time` DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '时间',
  `status` ENUM('已关注','取消关注') DEFAULT '已关注' COMMENT '状态',
  FOREIGN KEY (`follower_id`) REFERENCES `users`(`user_id`),
  FOREIGN KEY (`followed_id`) REFERENCES `users`(`user_id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='关注表';

