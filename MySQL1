-- 11. 微博-话题关联表
-- ----------------------------
DROP TABLE IF EXISTS `weibo_topic_rel`;
CREATE TABLE `weibo_topic_rel` (
  `rel_id` INT PRIMARY KEY AUTO_INCREMENT NOT NULL COMMENT '关联ID',
