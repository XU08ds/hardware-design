-- 13. 热搜表
-- ----------------------------
DROP TABLE IF EXISTS `hot_search`;
CREATE TABLE `hot_search` (
  `hot_id` INT PRIMARY KEY AUTO_INCREMENT NOT NULL COMMENT '热搜ID',
  `hot_title` VARCHAR(100) NOT NULL COMMENT '标题',
  `hot_score` INT DEFAULT 0 COMMENT '热度',
  `hot_level` ENUM('爆','热','新','沸') DEFAULT NULL COMMENT '等级',
  `topic_id` INT DEFAULT NULL COMMENT '话题ID',
  `is_top` ENUM('是','否') DEFAULT '否' COMMENT '置顶',
  `create_time` DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '时间',
  `status` ENUM('在榜','下架') DEFAULT '在榜' COMMENT '状态',
  FOREIGN KEY (`topic_id`) REFERENCES `topics`(`topic_id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='热搜表';

