-- 10. 话题表
-- ----------------------------
DROP TABLE IF EXISTS `topics`;
CREATE TABLE `topics` (
  `topic_id` INT PRIMARY KEY AUTO_INCREMENT NOT NULL COMMENT '话题ID',
  `topic_name` VARCHAR(100) NOT NULL UNIQUE COMMENT '话题名',
  `cover` VARCHAR(255) DEFAULT NULL COMMENT '封面',
  `read_count` INT DEFAULT 0 COMMENT '阅读量',
  `create_time` DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '时间'
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='话题表';

