-- 3. 微博图片表
-- ----------------------------
DROP TABLE IF EXISTS `weibo_images`;
CREATE TABLE `weibo_images` (
  `image_id` INT PRIMARY KEY AUTO_INCREMENT NOT NULL COMMENT '图片ID',
  `weibo_id` INT NOT NULL COMMENT '微博ID',
  `image_url` VARCHAR(255) NOT NULL COMMENT '图片地址',
  `sort` INT DEFAULT 0 COMMENT '排序',
  FOREIGN KEY (`weibo_id`) REFERENCES `weibo_posts`(`weibo_id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='微博图片表';

