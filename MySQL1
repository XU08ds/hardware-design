-- 12. 搜索记录表
-- ----------------------------
DROP TABLE IF EXISTS `search_record`;
CREATE TABLE `search_record` (
  `search_id` INT PRIMARY KEY AUTO_INCREMENT NOT NULL COMMENT '搜索ID',
  `user_id` INT DEFAULT NULL COMMENT '用户ID',
  `keyword` VARCHAR(100) NOT NULL COMMENT '关键词',
  `search_type` ENUM('内容','话题','用户') NOT NULL COMMENT '类型',
  `topic_id` INT DEFAULT NULL COMMENT '话题ID',
  `weibo_id` INT DEFAULT NULL COMMENT '微博ID',
  `target_user_id` INT DEFAULT NULL COMMENT '用户ID',
  `search_time` DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '时间',
  FOREIGN KEY (`user_id`) REFERENCES `users`(`user_id`),
  FOREIGN KEY (`topic_id`) REFERENCES `topics`(`topic_id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='搜索记录表';

